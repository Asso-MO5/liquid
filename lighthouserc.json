{
  "ci": {
    "collect": {
      "url": ["http://127.0.0.1:5173/fr"],
      "startServerCommand": "yarn dev --host 127.0.0.1",
      "startServerReadyPattern": "localhost|127.0.0.1|listening|ready|started",
      "startServerReadyTimeout": 120000,
      "numberOfRuns": 3,
      "settings": {
        "preset": "desktop",
        "chromeFlags": "--no-sandbox"
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": [
          "warn",
          {
            "minScore": 0.7
          }
        ],
        "categories:accessibility": [
          "error",
          {
            "minScore": 0.9
          }
        ],
        "categories:seo": [
          "error",
          {
            "minScore": 0.9
          }
        ],
        "categories:best-practices": [
          "warn",
          {
            "minScore": 0.8
          }
        ]
      }
    },
    "upload": {
      "target": "filesystem",
      "outputDir": ".lighthouseci"
    }
  }
}
